rules_version = '2';

// pun — Firestore 安全規則
//
// userPrefs 是個人偏好（例如「目前旅程」置頂），只允許本人讀寫，
// 因此不會外流給任何旅伴。trips / invites 沿用既有的細部權限。
service cloud.firestore {
  match /databases/{database}/documents {

    match /trips/{tripId} {
      // 任何已登入的人都可以讀取 (加入旅程時需要先讀取)
      allow read: if request.auth != null;

      // 建立：必須是 owner
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid;

      // 更新：owner、collaborator，或把自己加入 collaborators
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.collaborators ||
        request.auth.uid in request.resource.data.collaborators
      );

      // 刪除：只有 owner
      allow delete: if request.auth != null &&
        resource.data.ownerId == request.auth.uid;
    }

    match /invites/{code} {
      // 任何已登入的人都可以讀取邀請碼
      allow read: if request.auth != null;
      // 建立/刪除：必須是 owner
      allow write: if request.auth != null;
    }

    // 個人偏好（例如「目前旅程」置頂）— 只有本人可讀寫，不分享給旅伴
    match /userPrefs/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
